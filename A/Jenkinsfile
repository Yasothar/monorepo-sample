pipeline {
    agent any

    stages {
        stage('Detect and Build Project A') {
            when {
                changeset "A/**"
            }
            steps {
                echo 'Changes detected in Project A. Starting build...'
                dir('A') {
                    bat 'echo Building Project A...'
                }
            }
        }
    }
    
    post {
        success {
            echo 'Build completed successfully.'
        }
        cleanup {
            // Using cleanup block ensures it only wipes if a workspace was allocated
            cleanWs() 
        }
    }
}